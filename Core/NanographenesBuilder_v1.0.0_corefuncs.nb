Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"gallaiEdmondsDecomposition", "[", "graph_", "]"}], ":=", 
   RowBox[{"Block", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
      "glen", ",", "\[IndentingNewLine]", "matching", ",", "trees", ",", 
       "\[IndentingNewLine]", "len", ",", "SDlist", ",", "tree", ",", 
       "\[IndentingNewLine]", "vrts", ",", "vtps", ",", "s", ",", "d", ",", 
       "\[IndentingNewLine]", "Sset", ",", "Dset", ",", "Cset"}], 
      "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"glen", "=", 
       RowBox[{"Length", "[", "graph", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"matching", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "glen", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"matching", ",", "trees"}], "}"}], "=", 
       RowBox[{"maxMatching", "[", 
        RowBox[{"matching", ",", "graph"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"If", "[", "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{"FreeQ", "[", 
         RowBox[{"matching", ",", "0"}], "]"}], ",", "\[IndentingNewLine]", 
        "\t", 
        RowBox[{"{", 
         RowBox[{"matching", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", "}"}], ",", 
            RowBox[{"{", "}"}], ",", 
            RowBox[{"Range", "[", "glen", "]"}]}], "}"}]}], "}"}], 
        "\[IndentingNewLine]", "\t", ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"len", "=", 
          RowBox[{"Length", "[", "trees", "]"}]}], ";", "\[IndentingNewLine]",
          "\t", 
         RowBox[{"SDlist", "=", 
          RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t ", 
          RowBox[{
           RowBox[{
            RowBox[{"tree", "=", 
             RowBox[{
             "trees", "\[LeftDoubleBracket]", "i", 
              "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", "\t ", 
            RowBox[{"vrts", "=", 
             RowBox[{"Select", "[", 
              RowBox[{
               RowBox[{"Flatten", "[", 
                RowBox[{"Position", "[", 
                 RowBox[{"tree", ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"_", "?", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"#", "=!=", "0"}], "&"}], ")"}]}], ",", "_"}], 
                   "}"}]}], "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"#", "<=", "glen"}], "&"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", "\t ", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t", 
             RowBox[{
              RowBox[{"vrts", "=!=", 
               RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", "\t\t", 
              RowBox[{
               RowBox[{"vtps", "=", 
                RowBox[{"tree", "\[LeftDoubleBracket]", 
                 RowBox[{"vrts", ",", "2"}], "\[RightDoubleBracket]"}]}], ";",
                "\[IndentingNewLine]", "\t\t", 
               RowBox[{"s", "=", 
                RowBox[{"{", "}"}]}], ";", 
               RowBox[{"d", "=", 
                RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\t\t", 
               RowBox[{"Do", "[", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    "vtps", "\[LeftDoubleBracket]", "i", 
                    "\[RightDoubleBracket]"}], "===", "1"}], ",", 
                   RowBox[{"AppendTo", "[", 
                    RowBox[{"s", ",", 
                    RowBox[{
                    "vrts", "\[LeftDoubleBracket]", "i", 
                    "\[RightDoubleBracket]"}]}], "]"}], ",", 
                   RowBox[{"AppendTo", "[", 
                    RowBox[{"d", ",", 
                    RowBox[{
                    "vrts", "\[LeftDoubleBracket]", "i", 
                    "\[RightDoubleBracket]"}]}], "]"}]}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i", ",", 
                   RowBox[{"Length", "[", "vrts", "]"}]}], "}"}]}], "]"}], ";",
                "\[IndentingNewLine]", "\t\t", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"SDlist", ",", 
                 RowBox[{"{", 
                  RowBox[{"s", ",", "d"}], "}"}]}], "]"}]}]}], 
             "\[IndentingNewLine]", "\t ", "]"}]}], 
           RowBox[{"(*", " ", 
            RowBox[{
            "end", " ", "If", " ", "vrts", " ", "is", " ", "not", " ", 
             "empty"}], " ", "*)"}], ",", "\[IndentingNewLine]", "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", " ", 
          RowBox[{"end", " ", "Do"}], " ", "*)"}], ";", "\[IndentingNewLine]",
          "\[IndentingNewLine]", "\t", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Sset", ",", "Dset"}], "}"}], "=", 
          RowBox[{
           RowBox[{
            RowBox[{"Union", "@@", "#"}], "&"}], "/@", 
           RowBox[{"(", 
            RowBox[{"SDlist", "\[Transpose]"}], ")"}]}]}], ";", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Cset", "=", 
          RowBox[{"Complement", "[", 
           RowBox[{
            RowBox[{"Range", "[", "glen", "]"}], ",", "Sset", ",", "Dset"}], 
           "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", "\t", 
         RowBox[{"{", 
          RowBox[{"matching", ",", 
           RowBox[{"{", 
            RowBox[{"Dset", ",", "Sset", ",", "Cset"}], "}"}]}], "}"}]}]}], 
       "\[IndentingNewLine]", "]"}]}]}], 
    RowBox[{"(*", " ", 
     RowBox[{"end", " ", "If", " ", "a", " ", "perfect", " ", "matching"}], 
