         RowBox[{"{", "}"}]}], ",", 
        RowBox[{"Bvrts", "=", 
         RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"vls", "=", 
         RowBox[{"{", "}"}]}], ",", 
        RowBox[{"pks", "=", 
         RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", "pt1", ",", 
        "pt2"}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"len", "=", 
        RowBox[{"Length", "[", "graph", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"v1", "=", 
        RowBox[{"a0", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            SqrtBox["3"], "/", "2"}], ",", 
           RowBox[{"1", "/", "2"}], ",", "0"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"v2", "=", 
        RowBox[{"a0", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             SqrtBox["3"]}], "/", "2"}], ",", 
           RowBox[{"1", "/", "2"}], ",", "0"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"v3", "=", 
        RowBox[{"a0", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"-", "1"}], ",", "0"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{"i", "=!=", "j"}], ",", "\[IndentingNewLine]", "\t\t", 
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{
              "graph", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}],
               "-", 
              RowBox[{
              "graph", "\[LeftDoubleBracket]", "i", 
               "\[RightDoubleBracket]"}]}]}], ";", "\[IndentingNewLine]", 
            "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
