     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
       "len", ",", "\[IndentingNewLine]", "v1", ",", "v2", ",", "v3", ",", 
        "\[IndentingNewLine]", "vec", ",", "\[IndentingNewLine]", 
