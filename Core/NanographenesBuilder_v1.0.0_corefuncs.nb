             RowBox[{"AppendTo", "[", 
              RowBox[{"pks", ",", "j"}], "]"}]}]}], "\[IndentingNewLine]", 
           "\t", "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"i", ",", "Avrts"}], "}"}], ",", 
