Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"listOfBonds", "[", 
    RowBox[{
    "unitcell_", ",", "bondlength_", ",", "projection_", ",", "delta_"}], 
    "]"}], ":=", 
   RowBox[{"Catch", "[", "\[IndentingNewLine]", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{"len", ",", "vec", ",", 
        RowBox[{"bondlist", "=", 
         RowBox[{"{", "}"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"len", "=", 
        RowBox[{"Length", "[", "unitcell", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Switch", "[", "\[IndentingNewLine]", "\t", 
        RowBox[{"projection", ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1", ",", "0"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"XY", "-", 
           RowBox[{"plane", " ", "projection"}]}], "*)"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", 
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
                "]"}], "<", "delta"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"bondlist", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"j", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], "}"}]}],
                "]"}]}], 
             RowBox[{"(*", 
              RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]",
              "\t\t", "]"}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "Do"}], "*)"}], ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"{", 
          RowBox[{"1", ",", "0", ",", "1"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"XZ", "-", 
           RowBox[{"plane", " ", "projection"}]}], "*)"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", 
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
                "]"}], "<", "delta"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"bondlist", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "]"}], ",", 
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"j", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "]"}]}], "}"}]}],
                "]"}]}], 
             RowBox[{"(*", 
              RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]",
              "\t\t", "]"}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "Do"}], "*)"}], ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1", ",", "1"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"YZ", "-", 
           RowBox[{"plane", " ", "projection"}]}], "*)"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", 
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
                "]"}], "<", "delta"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"bondlist", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", 
                    RowBox[{"{", 
                    RowBox[{"2", ",", "3"}], "}"}]}], "]"}], "]"}], ",", 
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"j", ",", 
                    RowBox[{"{", 
                    RowBox[{"2", ",", "3"}], "}"}]}], "]"}], "]"}]}], "}"}]}],
                "]"}]}], 
             RowBox[{"(*", 
              RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]",
              "\t\t", "]"}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "Do"}], "*)"}], ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1", ",", "1"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"full", " ", "3", "D", " ", "space"}], "*)"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", 
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
                "]"}], "<", "delta"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"bondlist", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], ",", 
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", "j", "]"}], "]"}]}], "}"}]}], "]"}]}], 
             RowBox[{"(*", 
              RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]",
              "\t\t", "]"}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "Do"}], "*)"}], ",", "\[IndentingNewLine]", 
         "\t", "_", ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"Throw", "[", "$Failed", "]"}]}], "\[IndentingNewLine]", 
        "]"}], 
       RowBox[{"(*", 
        RowBox[{"end", " ", "Switch"}], "*)"}], ";", "\[IndentingNewLine]", 
       "bondlist"}]}], "\[IndentingNewLine]", "]"}], 
    RowBox[{"(*", 
     RowBox[{"end", " ", "Block"}], " ", "*)"}], "]"}]}], 
  RowBox[{"(*", 
   RowBox[{"end", " ", "Catch"}], "*)"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9912735562894783`*^9, 
  3.991273557569229*^9}},ExpressionUUID->"0460440a-7d24-4444-8731-\
979f3e83a7ff"]
}, Closed]],

Cell[CellGroupData[{

Cell["exportCXxyz", "Subsection",
 CellChangeTimes->{{3.991273534970991*^9, 3.991273545918089*^9}, {
  3.9912735821846657`*^9, 
  3.991273585321928*^9}},ExpressionUUID->"9f2f426b-e156-7449-95ad-\
c42e8e57ab30"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"exportCXxyz", "[", 
    RowBox[{
    "graph_", ",", "CCbondlength_", ",", "CXbondlength_", ",", "Xlabel_", ",",
      "path_", ",", "tag_"}], "]"}], ":=", 
   RowBox[{"Block", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{"ln", ",", "rm1", ",", "rm2", ",", "dir", ",", 
       RowBox[{"delta", "=", "0.3"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Hatomspos", "=", 
        RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", "nnatoms", ",", "v",
        ",", "vec", ",", "vert", ",", "\[IndentingNewLine]", "v1", ",", "v2", 
       ",", "v3", ",", "\[IndentingNewLine]", "coords", ",", "firstline", ",",
        "secondline", ",", "\[IndentingNewLine]", "body", ",", "text", ",", 
       "str", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", "ps", ",", 
       "nd"}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", "subfunctions", " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ps", "=", " ", 
       RowBox[{
        RowBox[{"Row", "[", 
         RowBox[{"#", ",", "\"\<\\t\>\""}], "]"}], "&"}]}], ";", 
      RowBox[{"(*", " ", 
       RowBox[{"parts", " ", "separation", " ", "function"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"nd", "=", 
       RowBox[{
        RowBox[{"PaddedForm", "[", 
         RowBox[{
          RowBox[{"1.0", " ", "#"}], ",", 
          RowBox[{"{", 
           RowBox[{"9", ",", "6"}], "}"}]}], "]"}], "&"}]}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{"number", " ", "display", " ", "function"}], " ", "*)"}], 
      "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ln", "=", 
       RowBox[{"Length", "[", "graph", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"rm1", "=", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         FractionBox["\[Pi]", "3"], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rm2", "=", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["\[Pi]", "3"]}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"v1", "=", 
       RowBox[{"CXbondlength", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           SqrtBox["3"], "/", "2"}], ",", 
          RowBox[{"1", "/", "2"}], ",", "0"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"v2", "=", 
       RowBox[{"CXbondlength", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            SqrtBox["3"]}], "/", "2"}], ",", 
          RowBox[{"1", "/", "2"}], ",", "0"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"v3", "=", 
       RowBox[{"CXbondlength", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{
         RowBox[{"nnatoms", "=", 
          RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"v", "=", 
             RowBox[{
              RowBox[{
              "graph", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}],
               "-", 
              RowBox[{
              "graph", "\[LeftDoubleBracket]", "j", 
               "\[RightDoubleBracket]"}]}]}], ";", "\[IndentingNewLine]", 
            "\t\t", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 SqrtBox[
                  RowBox[{"v", ".", "v"}]], "-", "CCbondlength"}], "]"}], "<",
                "delta"}], ",", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"nnatoms", ",", 
                RowBox[{
                "graph", "\[LeftDoubleBracket]", "j", 
                 "\[RightDoubleBracket]"}]}], "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Length", "@", "nnatoms"}], ">", "2"}], ",", 
              RowBox[{"Break", "[", "]"}]}], "]"}]}], ",", 
           "\[IndentingNewLine]", "\t", 
           RowBox[{"{", 
            RowBox[{"j", ",", "ln"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", "\t", 
         RowBox[{"Switch", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{"Length", "@", "nnatoms"}], ",", "\[IndentingNewLine]", 
           "\t\t", "2", ",", "\[IndentingNewLine]", "\t\t", 
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{"-", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                "nnatoms", "\[LeftDoubleBracket]", "1", 
                 "\[RightDoubleBracket]"}], "-", 
                RowBox[{
                "graph", "\[LeftDoubleBracket]", "i", 
                 "\[RightDoubleBracket]"}], "+", 
                RowBox[{
                "nnatoms", "\[LeftDoubleBracket]", "2", 
                 "\[RightDoubleBracket]"}], "-", 
                RowBox[{
                "graph", "\[LeftDoubleBracket]", "i", 
                 "\[RightDoubleBracket]"}]}], ")"}]}]}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{
                FractionBox["vec", 
                 SqrtBox[
                  RowBox[{"vec", ".", "vec"}]]], " ", "CXbondlength"}]}]}], 
             "]"}]}], ",", "\[IndentingNewLine]", "\t\t", "1", ",", 
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{"-", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                "nnatoms", "\[LeftDoubleBracket]", "1", 
                 "\[RightDoubleBracket]"}], "-", 
                RowBox[{
                "graph", "\[LeftDoubleBracket]", "i", 
                 "\[RightDoubleBracket]"}]}], ")"}]}]}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  FractionBox["vec", 
                   SqrtBox[
                    RowBox[{"vec", ".", "vec"}]]], " ", "CXbondlength"}], 
                 ")"}], ".", " ", "rm1"}]}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  FractionBox["vec", 
                   SqrtBox[
                    RowBox[{"vec", ".", "vec"}]]], " ", "CXbondlength"}], 
                 ")"}], ".", " ", "rm2"}]}]}], "]"}]}], ",", 
           "\[IndentingNewLine]", "\t\t", "0", ",", "\[IndentingNewLine]", 
           "\t\t", 
           RowBox[{
            RowBox[{"dir", "=", 
             RowBox[{"RandomChoice", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{"dir", " ", "v1"}]}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{"dir", " ", "v2"}]}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{"dir", " ", "v3"}]}]}], "]"}]}]}], 
          "\[IndentingNewLine]", "\t", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"i", ",", "ln"}], "}"}]}], "]"}], ";", "\[IndentingNewLine]",
       "\[IndentingNewLine]", 
      StyleBox[
       RowBox[{"(*", " ", 
        RowBox[{"Export", " ", "to", " ", "text", " ", "file"}], " ", "*)"}],
       FontSize->16], 
      StyleBox["\[IndentingNewLine]",
       FontSize->16], 
      StyleBox[
       RowBox[{"(*", " ", 
        RowBox[{"coo", " ", "file", " ", "creation"}], " ", "*)"}],
       FontSize->16], 
      StyleBox["\[IndentingNewLine]",
       FontSize->16], "\[IndentingNewLine]", 
      RowBox[{"vert", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"ConstantArray", "[", 
            RowBox[{"\"\<C\>\"", ",", "ln"}], "]"}], ",", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"Xlabel", ",", 
