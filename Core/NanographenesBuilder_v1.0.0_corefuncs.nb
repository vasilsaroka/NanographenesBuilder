Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"nnGraph", "[", 
     RowBox[{"vrtscoords_", ",", "bondlength_", ",", "delta_"}], "]"}], ":=", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
       "len", ",", "\[IndentingNewLine]", "vec", ",", "\[IndentingNewLine]", 
        "graph"}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"len", "=", 
        RowBox[{"Length", "[", "vrtscoords", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graph", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "len"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"vec", "=", 
           RowBox[{
            RowBox[{"vrtscoords", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "-", 
            RowBox[{"vrtscoords", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{
                RowBox[{"Sqrt", "[", 
                 RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
               "]"}], "<", "delta"}], ")"}], ",", "\[IndentingNewLine]", "\t", 
            RowBox[{
             RowBox[{"AppendTo", "[", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], ",", "j"}], "]"}], ";", 
             "\[IndentingNewLine]", "\t", 
             RowBox[{"AppendTo", "[", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "j", 
                "\[RightDoubleBracket]"}], ",", "i"}], "]"}]}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]", 
           "]"}]}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"len", "-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
       RowBox[{"(*", 
        RowBox[{"end", " ", "Do"}], "*)"}], ";", "\[IndentingNewLine]", 
       "graph"}]}], "\[IndentingNewLine]", "]"}]}], 
   RowBox[{"(*", " ", 
    RowBox[{"end", " ", "Block"}], " ", "*)"}], ";"}], 
  "\[IndentingNewLine]"}]], "Input",
