                    RowBox[{"vec", "-", "v1"}], ")"}]}], "]"}], "<", 
                 "\[Delta]"}], ")"}], "||", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Abs", "[", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"vec", "-", "v2"}], ")"}], ".", 
                   RowBox[{"(", 
                    RowBox[{"vec", "-", "v2"}], ")"}]}], "]"}], "<", 
                 "\[Delta]"}], ")"}], "||", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Abs", "[", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"vec", "-", "v3"}], ")"}], ".", 
                   RowBox[{"(", 
                    RowBox[{"vec", "-", "v3"}], ")"}]}], "]"}], "<", 
                 "\[Delta]"}], ")"}]}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"Avrts", ",", "i"}], "]"}], ",", "\[IndentingNewLine]",
               "\t\t\t", 
              RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t\t", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"Abs", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"vec", "+", "v1"}], ")"}], ".", 
                    RowBox[{"(", 
                    RowBox[{"vec", "+", "v1"}], ")"}]}], "]"}], "<", 
                   "\[Delta]"}], ")"}], "||", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"Abs", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"vec", "+", "v2"}], ")"}], ".", 
                    RowBox[{"(", 
                    RowBox[{"vec", "+", "v2"}], ")"}]}], "]"}], "<", 
                   "\[Delta]"}], ")"}], "||", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"Abs", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"vec", "+", "v3"}], ")"}], ".", 
                    RowBox[{"(", 
                    RowBox[{"vec", "+", "v3"}], ")"}]}], "]"}], "<", 
                   "\[Delta]"}], ")"}]}], ",", "\[IndentingNewLine]", 
                "\t\t\t\t", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"Bvrts", ",", "i"}], "]"}]}], "\[IndentingNewLine]", 
               "\t\t\t", "]"}]}], "\[IndentingNewLine]", "\t\t", "]"}]}]}], 
          "\[IndentingNewLine]", "\t", "]"}], "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "len"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", "len"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Avrts", "=", 
        RowBox[{"Union", "[", "Avrts", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Bvrts", "=", 
        RowBox[{"Union", "[", "Bvrts", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{
          RowBox[{"pt1", "=", 
           RowBox[{
           "graph", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]}], 
          ";", "\[IndentingNewLine]", "\t", 
          RowBox[{"pt2", "=", 
           RowBox[{
           "graph", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]}], 
          ";", "\[IndentingNewLine]", "\t", 
          RowBox[{"vec", "=", 
           RowBox[{"pt2", "-", "pt1"}]}], ";", "\[IndentingNewLine]", "\t", 
          RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"vec", "-", "v3"}], ")"}], ".", 
                RowBox[{"(", 
                 RowBox[{"vec", "-", "v3"}], ")"}]}], "]"}], "<", 
